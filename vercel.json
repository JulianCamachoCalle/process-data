{
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-outbox",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/kommo-sync",
      "schedule": "10 3 * * *"
    },
    {
      "path": "/api/cron/kommo-process-events",
      "schedule": "20 3 * * *"
    }
  ]
}
